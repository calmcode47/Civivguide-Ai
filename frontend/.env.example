# CivicMind — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to version control.

# Local backend during development
VITE_API_BASE_URL=http://localhost:8080

# After Cloud Run deployment, replace with your HTTPS service URL:
# VITE_API_BASE_URL=https://your-cloud-run-service-xxxxx-uc.a.run.app

# Public site URL for SEO and social metadata
VITE_SITE_URL=https://projects-fef16.web.app

# Firebase web app configuration
